# Copy to .env.local for local dev, and set these in Vercel → Settings → Environment Variables for production.

# Required for the AI Assistant (/assistant). Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: lets the AI Assistant email leads to you (same Formspree form as the contact form).
# Create a free form at https://formspree.io and paste the ID (the part after /f/).
SIGNGO_FORMSPREE_ID=
